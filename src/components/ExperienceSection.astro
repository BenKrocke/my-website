---
import JobEntry from './JobEntry.astro';

const jobs = [
  {
    company: "Energy Bay - Diamond Energy",
    title: "Lead Software Developer", 
    period: "Jul. 2024 - Current",
    location: "Burnley, AUS",
    descriptions: [
      "Australian energy retailer offering sustainable, renewable electricity to homes and businesses",
      "Designed and built a payments processing platform using Azure Container Apps, Service Bus, and Functions, integrating NAB Gateway for Credit Card payments/tokenisation, and NAB Direct Link for direct debit/credit processing, with Infrastructure as Code (Bicep), and CI/CD pipelines across staging and production environments",
      "Led the end-to-end development of two customer portals using Next.js and ASP.NET, integrating FusionAuth for user authentication and deploying via Azure App Services with continuous deployment pipelines"
    ]
  },
  {
    company: "iO Digital",
    title: "Software Developer",
    period: "Aug. 2021 - Dec. 2022", 
    location: "'s-Hertogenbosch, NL",
    descriptions: [
      "End-to-end digital agency and team of experts specializing in communication and digital transformation",
      "Built and maintained .NET, React, and Sitecore components for the Dutch energy regulator Enexis website",
      "Utilized Sitecore PowerShell Extensions to automate processes and generate custom reports, reducing manual editor operations"
    ]
  },
  {
    company: "Fullcircle / Adabt",
    title: "Software Engineer",
    period: "May 2019 - Jul. 2021",
    location: "Eindhoven, NL", 
    descriptions: [
      "Software startup that pivoted to B2B integrations for transport and logistics",
      "Implemented data integrations between transport companies and their API protocols using TypeScript and Google Cloud Functions, significantly improving company scalability by reducing integration costs",
      "Developed a Laravel/Vue website connecting to the \"HappyBot\" product, enabling individuals on the autism spectrum to more easily identify (and log) their emotions"
    ]
  },
  {
    company: "Dotcombusiness",
    title: "Freelance Software Engineer",
    period: "Dec. 2016 - Dec. 2022",
    location: "Oss, NL",
    descriptions: [
      "IT automation services for small and medium-sized enterprises",
      "Implemented a .NET service ticket dashboard to monitor incoming service calls and track deadlines, improving service desk efficiency", 
      "Created SAP integration with a Laravel website enabling customers to track service tickets, reducing help desk calls and inquiries"
    ]
  },
  {
    company: "Amacom", 
    title: "Part-time Software Developer",
    period: "Jun. 2018 - Jan. 2019",
    location: "'s-Hertogenbosch, NL",
    descriptions: [
      "Leading supplier of consumer electronics and small domestic appliances in the Benelux region",
      "Contributed to the Amacom 'Quecom' order and information system by modernizing modules from Zend 1 to Symfony framework"
    ]
  },
  {
    company: "SBS",
    title: "Graphic Designer", 
    period: "Aug. 2014 - May 2018",
    location: "Amsterdam, NL",
    descriptions: [
      "Dutch free-to-cable commercial television channel",
      "Developed, designed, and executed daily post-production activities for Dutch news broadcasts 'Hart van Nederland' and 'Shownieuws', collaborating with editors and directors under strict deadlines",
      "Created infographics, animations, and graphics for broadcast content"
    ]
  }
];
---

<div class="section experience-section">
  <div class="section-title">Experience</div>
  {jobs.map((job) => (
    <JobEntry
      company={job.company}
      title={job.title}
      period={job.period}
      location={job.location}
      descriptions={job.descriptions}
    />
  ))}
</div>