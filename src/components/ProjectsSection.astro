---
const projects = [
  {
    name: "React Tower Defense",
    description: "Interactive browser-based tower defense game built with React, featuring real-time gameplay mechanics, wave-based enemy spawning, and responsive UI design"
  },
  {
    name: "HTTP Web Server in C", 
    description: "HTTP web server implemented from scratch in C using UNIX sockets"
  },
  {
    name: "CHIP-8 Emulator",
    description: "Complete CHIP-8 CPU emulator written in Rust with test-driven development approach, featuring cycle-accurate instruction execution and graphics rendering"
  },
  {
    name: "Prism 3D Game Engine",
    description: "Cross-platform 3D tower defense game engine built with C++, SDL2, and OpenGL, featuring custom rendering pipeline, physics simulation, and asset management system"
  }
];
---

<div class="section">
  <div class="section-title">Projects</div>
  <div class="projects-grid">
    {projects.map((project) => (
      <div class="project-item">
        <div class="project-name">{project.name}</div>
        <div class="project-description">{project.description}</div>
      </div>
    ))}
  </div>
</div>