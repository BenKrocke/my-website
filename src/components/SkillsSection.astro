---
const skills = {
  mainExperience: "JavaScript, C#, PHP, TypeScript, Rust",
  otherExperience: "C++, SQL", 
  frameworks: "React, Sitecore, .NET, Laravel, Vue, Google Cloud",
  certifications: "Sitecore Experience Solution 9 Developer Certification"
};
---

<div class="section">
  <div class="section-title">Skills</div>
  <div class="skills-grid">
    <div>
      <div class="skill-category">
        <div class="skill-title">Main Experience:</div>
        <div class="skill-list">{skills.mainExperience}</div>
      </div>
      <div class="skill-category">
        <div class="skill-title">Other Experience:</div>
        <div class="skill-list">{skills.otherExperience}</div>
      </div>
    </div>
    <div>
      <div class="skill-category">
        <div class="skill-title">Frameworks/Libraries:</div>
        <div class="skill-list">{skills.frameworks}</div>
      </div>
      <div class="skill-category">
        <div class="skill-title">Certifications:</div>
        <div class="skill-list">{skills.certifications}</div>
      </div>
    </div>
  </div>
</div>