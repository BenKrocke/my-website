---
const skills = {
  frontend: "React, TypeScript, HTML/CSS",
  backend: "ASP.NET, Flask, Laravel, Node.js", 
  cloud: "Azure, AWS",
  tools: "Sitecore, Git, Figma, Adobe, Office"
};
---

<div class="section">
  <div class="section-title">Skills</div>
  <div class="skills-grid">
    <div>
      <div class="skill-category">
        <div class="skill-title">Frontend:</div>
        <div class="skill-list">{skills.frontend}</div>
      </div>
      <div class="skill-category">
        <div class="skill-title">Cloud:</div>
        <div class="skill-list">{skills.cloud}</div>
      </div>
    </div>
    <div>
      <div class="skill-category">
        <div class="skill-title">Backend:</div>
        <div class="skill-list">{skills.backend}</div>
      </div>
      <div class="skill-category">
        <div class="skill-title">Tools:</div>
        <div class="skill-list">{skills.tools}</div>
      </div>
    </div>
  </div>
</div>